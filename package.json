{
  "name": "screenplay-studio",
  "version": "0.5.0",
  "description": "A Chinese-first screenplay writing and offline production planning app with Hollywood formatting, FDX, PDF, and department handoffs.",
  "license": "MIT",
  "author": "1037 Film 郭之然",
  "type": "module",
  "main": "electron/main.cjs",
  "repository": {
    "type": "git",
    "url": "https://github.com/uberadamfor4-ui/screenplay-studio.git"
  },
  "bugs": {
    "url": "https://github.com/uberadamfor4-ui/screenplay-studio/issues"
  },
  "homepage": "https://github.com/uberadamfor4-ui/screenplay-studio#readme",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on http://127.0.0.1:5173 && cross-env SCREENPLAY_DEV=1 electron .\"",
    "build": "tsc -b && vite build",
    "dist": "npm run build && electron-builder --win nsis",
    "dist:win": "npm run build && electron-builder --win nsis",
    "dist:mac": "npm run build && electron-builder --mac dmg zip",
    "pack": "npm run build && electron-builder --win dir",
    "pack:mac": "npm run build && electron-builder --mac dir",
    "start": "electron .",
    "lint": "oxlint",
    "test": "tsx --test tests/*.test.ts",
    "preview": "vite preview"
  },
  "build": {
    "appId": "studio.screenplay.writer",
    "productName": "Screenplay Studio",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "assets/brand/*",
      "THIRD_PARTY_NOTICES.md",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "src/assets/fonts",
        "to": "fonts",
        "filter": [
          "NotoSansCJKsc-Regular.otf",
          "OFL.txt"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/brand/app-icon.ico",
      "artifactName": "Screenplay-Studio-${version}-Setup.${ext}"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.productivity",
      "icon": "assets/brand/app-icon-512.png",
      "artifactName": "Screenplay-Studio-${version}-${arch}.${ext}",
      "minimumSystemVersion": "10.15",
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "identity": null
    },
    "dmg": {
      "title": "Screenplay Studio ${version}",
      "artifactName": "Screenplay-Studio-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Screenplay Studio",
      "uninstallDisplayName": "Screenplay Studio"
    }
  },
  "dependencies": {
    "@fontsource/courier-prime": "^5.2.8",
    "@napi-rs/canvas": "^0.1.80",
    "lucide-react": "^1.23.0",
    "mammoth": "^1.12.0",
    "pdf-parse": "^2.4.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "oxlint": "^1.71.0",
    "tsx": "^4.23.1",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "wait-on": "^9.0.10"
  }
}
